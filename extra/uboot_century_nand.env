echo MontageTech M88CC8000 Uboot

#linux폘땡꽝鑒돨코닸토零
#
# 244-248M for avenv_VID_SD_WR_BACK_ADDR
#
setenv memargs mem=244M mmz=av,0,0,64M mmz=ddr,0,0,32M
if test $chipver -eq 0x0d;then
setenv memargs mem=244M mmz=av,0,0,76M mmz=ddr,0,0,32M
fi
if test $chipver -eq 0x0e;then
setenv memargs mem=244M mmz=av,0,0,76M mmz=ddr,0,0,32M
fi
if test $chipver -eq 0x0f;then
setenv memargs mem=244M mmz=av,0,0,76M mmz=ddr,0,0,32M
fi


#linux폘땡꽝鑒돨MTD롸혐토零


#linux폘땡꽝鑒
setenv mtdparts mtdparts=mt_snf:512k(btinit.img),1024k(uboot.img),256k(boot.scr),256k(logo),1M(av_cpu.img),5M(kernel.img),12M(rootfs),20M(usrfs.img),20M(datafs.img),4M(loaderdb),-(user)

#setenv bootargs console=ttyS0,115200n8 console=ttyUSB0,115200n8 cpuclock=54M no_console_suspend uboot_tvsys_set ubi.mtd=6 root=ubi0:rootfs ro rootfstype=ubifs $memargs ubi.mtd=7 ubi.block=1,0 ubi.mtd=8,2048 apppart=ubiblock1_0 appfs=squashfs $mtdparts
setenv bootargs console=ttyS0,115200n8 console=ttyUSB0,115200n8 cpuclock=54M no_console_suspend uboot_tvsys_set msp.sd_wrback_addr=0xf400000 ubi.mtd=6 root=ubi0:rootfs ro rootfstype=ubifs $memargs ubi.mtd=7 ubi.block=1,0 ubi.mtd=8,2048 apppart=ubiblock1_0 appfs=squashfs $mtdparts

setenv load_off 0x300000
setenv load_size 0x500000
setenv rd_start RD_START0
setenv rd_start_uc RD_START_UC0
setenv rd_size RD_SIZE0

snf probe

#logo
setenv read_logo loadimg 0 0x1c0000 0x20000 0x89800000
# 152M-176M
setenv jpeg_env "setenv avenv_AVCPU_CONFIG 128M_AD_HEVC ; setenv avenv_JPEG_SRC_ADDR 0xa9800000 ; setenv avenv_JPEG_SRC_SIZE 0x200000 ; setenv avenv_JPEG_HEAP_ADDR 0xa9a00000 ; setenv avenv_JPEG_HEAP_SIZE 0x1600000"
# 244M
setenv vid_env "setenv avenv_VID_SD_WR_BACK_SIZE 0x32a000 ; setenv avenv_VID_SD_WR_BACK_FIELD_NO 0x4 ; setenv avenv_VID_SD_WR_BACK_ADDR 0xaf400000 ; setenv avenv_SD_ENABLE 1"
# 176M-184M
setenv osd_graphic_env "setenv jpgenv_OSD_BUF_ADDR 0xab000000 ; setenv jpgenv_OSD_LAYER 5 ; setenv jpgenv_GRAPHIC_SIZE_WIDTH 1280 ; setenv jpgenv_GRAPHIC_SIZE_HEIGHT 720 ; jpeg_logo"
run symphony_logo


#enter usb upgrade

#enter ota upgrade


loader_set0 -p loaderdb -b snf

if test "$bootimage" = "loader"; then
loader_set1 -p loader -b snf
else
loader_set1 -p kernel.img -b snf
#속潼avcpu미숭
loadimg 1 lzma 0x200000 0x81500000 0xafd10000
#폘땡avcpu
cpu 1 release 8fd10000

fi

if test "$rd_start" != "RD_START0"; then
setenv ramdiskaddr 0x00002000
loadimg 0 $ramdiskaddr $rd_size $rd_start
setenv bootargs $bootargs rd_start=$rd_start rd_size=$rd_size
fi


loadimg 0 $load_off $load_size 0x83000000

#mw.b
#####mw end flag#####

dcache flush

#enable secure for ddr protect here

bootm 0x83000000




